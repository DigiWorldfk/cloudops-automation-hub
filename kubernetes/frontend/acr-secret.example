# acr-secret.example — TEMPLATE ONLY, DO NOT PUT REAL VALUES HERE
#
# Create the ACR pull secret in every namespace that pulls images:
#
#   az acr login --name <acr-name> --expose-token \
#     --output tsv --query accessToken | \
#   kubectl create secret docker-registry acr-secret \
#     --namespace=<namespace> \
#     --docker-server=<acr-name>.azurecr.io \
#     --docker-username=00000000-0000-0000-0000-000000000000 \
#     --docker-password="$(az acr login --name <acr-name> --expose-token --query accessToken -o tsv)"
#
# Alternatively, attach the ACR to the AKS cluster (no pull secret needed):
#
#   az aks update \
#     --name <aks-name> \
#     --resource-group <rg-name> \
#     --attach-acr <acr-name>
