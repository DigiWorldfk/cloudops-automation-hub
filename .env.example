# CloudOps Automation Hub — Environment Variables
# Copy this file to .env and fill in all values before starting.
# .env is in .gitignore — NEVER commit it to version control.

# ── Authentication ─────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=change-me-to-a-random-64-char-string-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Access token TTL in minutes (default 15)
JWT_ACCESS_TTL_MINUTES=15
# Refresh token TTL in days (default 7)
JWT_REFRESH_TTL_DAYS=7

# Admin username
ADMIN_USER=admin

# bcrypt hash of admin password (rounds=12)
# Generate with: python3 -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('YourPasswordHere'))"
ADMIN_PASS_HASH=$2b$12$ChangeThisToARealBcryptHashOfYourPassword

# Admin role (admin | engineer | readonly)
ADMIN_ROLE=admin

# TOTP secret — base32 encoded
# Generate with: python3 -c "import pyotp; print(pyotp.random_base32())"
# Add to your authenticator app (Google Authenticator, Authy, 1Password, etc.)
TOTP_SECRET=JBSWY3DPEHPK3PXP

# ── Database ────────────────────────────────────────────────────────────────
DB_PATH=/app/data/cloudops.db

# ── Azure ──────────────────────────────────────────────────────────────────
# Service Principal credentials (az ad sp create-for-rbac --name cloudops-hub --role Contributor)
AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default VNet/Subnet for VM creation (must exist in the target Resource Group)
AZURE_DEFAULT_VNET=cloudops-vnet
AZURE_DEFAULT_SUBNET=default

# ── AWS ────────────────────────────────────────────────────────────────────
# IAM user with EC2, SSM, and Cost Explorer read/write permissions
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_DEFAULT_REGION=us-east-1

# ── Kubernetes ─────────────────────────────────────────────────────────────
# Path to kubeconfig inside the container (mount the file via docker-compose volumes)
# KUBECONFIG=/root/.kube/config

# ── Terraform ──────────────────────────────────────────────────────────────
TERRAFORM_WORKSPACES=/app/terraform-workspaces
# ── AI Agent (OpenAI / Azure OpenAI) ─────────────────────────────────
# Option A: Azure OpenAI (recommended if you already have Azure credentials)
# Create a deployment in Azure OpenAI Studio and copy the endpoint + key.
# AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
# AZURE_OPENAI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-10-21
#
# Option B: Standard OpenAI API
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4o
